/ {
    chosen {
        zephyr,display = &oled;
    };
};

&i2c0 {
    status = "okay";
    oled: ssd1306@3c {
        compatible = "solomon,ssd1306fb";
        reg = <0x3c>;
        width = <128>;
        height = <64>;       /* 128x64 모델이면 64 */
        segment-offset = <0>;
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <63>; /* 128x64 모델이면 63 */
        segment-remap;
        com-invdir;
        com-sequential;
        prechargep = <0x22>;
    };
};
